{
  "id": "dk.kitchey.homey",
  "version": "1.1.0",
  "compatibility": ">=5.0.0",
  "sdk": 3,
  "name": {
    "en": "Kitchey",
    "da": "Kitchey"
  },
  "description": {
    "en": "Connect your Kitchey fridge inventory to Homey flows.",
    "da": "Forbind dit Kitchey-lager til Homey-flows."
  },
  "category": ["tools"],
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png"
  },
  "author": {
    "name": "Kitchey",
    "email": "kundeservice@aihuset.dk"
  },
  "capabilities": {
    "measure_item_count": {
      "type": "number",
      "title": { "en": "Items", "da": "Varer" },
      "units": { "en": "items", "da": "varer" },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "icon": "/assets/icon.svg",
      "insights": true
    },
    "measure_expiring_3d": {
      "type": "number",
      "title": { "en": "Expiring within 3 days", "da": "Udløber inden 3 dage" },
      "units": { "en": "items", "da": "varer" },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "icon": "/assets/icon.svg",
      "insights": true
    },
    "measure_expiring_7d": {
      "type": "number",
      "title": { "en": "Expiring within 7 days", "da": "Udløber inden 7 dage" },
      "units": { "en": "items", "da": "varer" },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "icon": "/assets/icon.svg",
      "insights": true
    },
    "measure_shopping_count": {
      "type": "number",
      "title": { "en": "Shopping list items", "da": "Indkøbsliste varer" },
      "units": { "en": "items", "da": "varer" },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "icon": "/assets/icon.svg",
      "insights": true
    }
  },
  "drivers": [
    {
      "id": "storage-unit",
      "name": { "en": "Storage Unit", "da": "Lagerenhed" },
      "class": "other",
      "capabilities": ["measure_item_count", "measure_expiring_3d", "measure_expiring_7d"],
      "capabilitiesOptions": {
        "measure_item_count": { "title": { "en": "Items on stock", "da": "Varer på lager" } },
        "measure_expiring_3d": { "title": { "en": "Expiring ≤3 days", "da": "Udløber ≤3 dage" } },
        "measure_expiring_7d": { "title": { "en": "Expiring ≤7 days", "da": "Udløber ≤7 dage" } }
      },
      "images": {
        "small": "/assets/images/small.png",
        "large": "/assets/images/large.png"
      },
      "pair": [
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": { "next": "add_devices" }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "settings": [
        {
          "id": "storage_unit_id",
          "type": "label",
          "label": { "en": "Storage Unit ID", "da": "Lagerenhed-ID" },
          "value": ""
        },
        {
          "id": "list_type",
          "type": "label",
          "label": { "en": "List type", "da": "Listetype" },
          "value": ""
        }
      ]
    },
    {
      "id": "shopping",
      "name": { "en": "Shopping List", "da": "Indkøbsliste" },
      "class": "other",
      "capabilities": ["measure_shopping_count"],
      "capabilitiesOptions": {
        "measure_shopping_count": { "title": { "en": "Unchecked items", "da": "Ikke-fundne varer" } }
      },
      "images": {
        "small": "/assets/images/small.png",
        "large": "/assets/images/large.png"
      },
      "pair": [
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": { "next": "add_devices" }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "settings": []
    }
  ],
  "flow": {
    "triggers": [
      {
        "id": "item_expires_soon",
        "title": {
          "en": "An item expires within {{days}} days",
          "da": "En vare udløber inden for {{days}} dage"
        },
        "titleFormatted": {
          "en": "An item expires within [[days]] days",
          "da": "En vare udløber inden for [[days]] dage"
        },
        "args": [
          {
            "type": "number",
            "name": "days",
            "title": { "en": "Days", "da": "Dage" },
            "min": 1,
            "max": 30,
            "step": 1
          }
        ],
        "tokens": [
          { "name": "item_name", "type": "string", "title": { "en": "Item name" } },
          { "name": "expiry_date", "type": "string", "title": { "en": "Expiry date" } },
          { "name": "quantity", "type": "number", "title": { "en": "Quantity" } }
        ]
      },
      {
        "id": "item_expires_today",
        "title": {
          "en": "An item expires today",
          "da": "En vare udløber i dag"
        },
        "tokens": [
          { "name": "item_name", "type": "string", "title": { "en": "Item name" } },
          { "name": "quantity", "type": "number", "title": { "en": "Quantity" } }
        ]
      },
      {
        "id": "shopping_count_above",
        "title": {
          "en": "Shopping list has more than {{count}} items",
          "da": "Indkøbslisten har mere end {{count}} varer"
        },
        "titleFormatted": {
          "en": "Shopping list has more than [[count]] items",
          "da": "Indkøbslisten har mere end [[count]] varer"
        },
        "args": [
          {
            "type": "number",
            "name": "count",
            "title": { "en": "Count", "da": "Antal" },
            "min": 1,
            "max": 100,
            "step": 1
          }
        ]
      }
    ],
    "actions": [
      {
        "id": "add_to_shopping",
        "title": {
          "en": "Add [[name]] to shopping list",
          "da": "Tilføj [[name]] til indkøbslisten"
        },
        "titleFormatted": {
          "en": "Add [[name]] to shopping list",
          "da": "Tilføj [[name]] til indkøbslisten"
        },
        "args": [
          {
            "type": "text",
            "name": "name",
            "title": { "en": "Item name", "da": "Varenavn" }
          },
          {
            "type": "number",
            "name": "quantity",
            "title": { "en": "Quantity", "da": "Antal" },
            "min": 1,
            "step": 1
          },
          {
            "type": "text",
            "name": "unit",
            "title": { "en": "Unit (e.g. stk, g, ml)", "da": "Enhed (fx stk, g, ml)" }
          }
        ]
      },
      {
        "id": "delete_shopping_item",
        "title": {
          "en": "Remove item [[item]] from shopping list",
          "da": "Fjern [[item]] fra indkøbslisten"
        },
        "titleFormatted": {
          "en": "Remove item [[item]] from shopping list",
          "da": "Fjern [[item]] fra indkøbslisten"
        },
        "args": [
          {
            "type": "autocomplete",
            "name": "item",
            "title": { "en": "Item", "da": "Vare" }
          }
        ]
      },
      {
        "id": "check_shopping_item",
        "title": {
          "en": "Mark [[item]] as found",
          "da": "Marker [[item]] som fundet"
        },
        "titleFormatted": {
          "en": "Mark [[item]] as found",
          "da": "Marker [[item]] som fundet"
        },
        "args": [
          {
            "type": "autocomplete",
            "name": "item",
            "title": { "en": "Item", "da": "Vare" }
          }
        ]
      },
      {
        "id": "use_item",
        "title": {
          "en": "Mark [[item]] as used ([[amount]]×)",
          "da": "Marker [[item]] som brugt ([[amount]]×)"
        },
        "titleFormatted": {
          "en": "Mark [[item]] as used [[amount]]×",
          "da": "Marker [[item]] som brugt [[amount]]×"
        },
        "args": [
          {
            "type": "autocomplete",
            "name": "item",
            "title": { "en": "Item", "da": "Vare" }
          },
          {
            "type": "number",
            "name": "amount",
            "title": { "en": "Amount", "da": "Antal" },
            "min": 1,
            "step": 1
          }
        ]
      },
      {
        "id": "add_inventory_item",
        "title": {
          "en": "Add [[product]] to inventory",
          "da": "Tilføj [[product]] til lageret"
        },
        "titleFormatted": {
          "en": "Add [[product]] to inventory",
          "da": "Tilføj [[product]] til lageret"
        },
        "args": [
          {
            "type": "autocomplete",
            "name": "product",
            "title": { "en": "Product", "da": "Produkt" }
          },
          {
            "type": "number",
            "name": "quantity",
            "title": { "en": "Quantity", "da": "Antal" },
            "min": 1,
            "step": 1
          },
          {
            "type": "dropdown",
            "name": "list_type",
            "title": { "en": "Storage type", "da": "Lagertype" },
            "values": [
              { "id": "fridge", "label": { "en": "Fridge", "da": "Køleskab" } },
              { "id": "freezer", "label": { "en": "Freezer", "da": "Fryser" } },
              { "id": "pantry", "label": { "en": "Pantry", "da": "Kolonial" } }
            ]
          },
          {
            "type": "date",
            "name": "expiry_date",
            "title": { "en": "Expiry date (optional)", "da": "Udløbsdato (valgfri)" }
          }
        ]
      },
      {
        "id": "create_catalog_product",
        "title": {
          "en": "Create catalog product [[name]]",
          "da": "Opret katalogprodukt [[name]]"
        },
        "titleFormatted": {
          "en": "Create catalog product [[name]]",
          "da": "Opret katalogprodukt [[name]]"
        },
        "args": [
          {
            "type": "text",
            "name": "name",
            "title": { "en": "Product name", "da": "Produktnavn" }
          },
          {
            "type": "dropdown",
            "name": "category",
            "title": { "en": "Category", "da": "Kategori" },
            "values": [
              { "id": "fridge", "label": { "en": "Fridge", "da": "Køleskab" } },
              { "id": "freezer", "label": { "en": "Freezer", "da": "Fryser" } },
              { "id": "pantry", "label": { "en": "Pantry", "da": "Kolonial" } }
            ]
          },
          {
            "type": "text",
            "name": "unit",
            "title": { "en": "Unit (e.g. stk, g, ml)", "da": "Enhed (fx stk, g, ml)" }
          },
          {
            "type": "text",
            "name": "brand",
            "title": { "en": "Brand (optional)", "da": "Mærke (valgfri)" }
          }
        ]
      },
      {
        "id": "create_storage_unit",
        "title": {
          "en": "Create storage unit [[name]]",
          "da": "Opret lagerenhed [[name]]"
        },
        "titleFormatted": {
          "en": "Create storage unit [[name]] ([[list_type]])",
          "da": "Opret lagerenhed [[name]] ([[list_type]])"
        },
        "args": [
          {
            "type": "text",
            "name": "name",
            "title": { "en": "Name", "da": "Navn" }
          },
          {
            "type": "dropdown",
            "name": "list_type",
            "title": { "en": "Type", "da": "Type" },
            "values": [
              { "id": "fridge", "label": { "en": "Fridge", "da": "Køleskab" } },
              { "id": "freezer", "label": { "en": "Freezer", "da": "Fryser" } },
              { "id": "pantry", "label": { "en": "Pantry", "da": "Kolonial" } }
            ]
          }
        ]
      },
      {
        "id": "create_shelf",
        "title": {
          "en": "Create shelf [[name]] in [[unit]]",
          "da": "Opret hylde [[name]] i [[unit]]"
        },
        "titleFormatted": {
          "en": "Create shelf [[name]] in [[unit]]",
          "da": "Opret hylde [[name]] i [[unit]]"
        },
        "args": [
          {
            "type": "text",
            "name": "name",
            "title": { "en": "Shelf name", "da": "Hyldenavn" }
          },
          {
            "type": "autocomplete",
            "name": "unit",
            "title": { "en": "Storage unit", "da": "Lagerenhed" }
          }
        ]
      }
    ]
  },
  "settings": [
    {
      "id": "server_url",
      "type": "text",
      "title": { "en": "Server URL", "da": "Server-URL" },
      "value": "https://kitchey.aihuset.dk",
      "hint": { "en": "Leave as default to use the Kitchey cloud server, or enter your self-hosted URL.", "da": "Lad stå som standard for at bruge Kitchey-cloudserveren, eller indtast din selvhostede URL." }
    },
    {
      "id": "token",
      "type": "password",
      "title": { "en": "Personal Access Token", "da": "Adgangsnøgle" },
      "value": "",
      "hint": { "en": "Generate a token in the Kitchey app: Settings → Advanced → API Keys.", "da": "Generer en nøgle i Kitchey-appen: Indstillinger → Avanceret → API-nøgler." }
    },
    {
      "id": "household_id",
      "type": "text",
      "title": { "en": "Household ID", "da": "Husstand-ID" },
      "value": "",
      "hint": { "en": "Your household ID. Found after saving the token in the Kitchey app.", "da": "Dit husstand-ID. Findes i Kitchey-appen efter du har gemt din nøgle." }
    }
  ]
}
